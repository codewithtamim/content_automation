# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_CHAT_ID=your_chat_id
ADMIN_TELEGRAM_USERNAME=your_username

# Database (SQLite, default path works out of the box)
# DATABASE_URL=sqlite:///data/tiktok_automation.db

# Optional: Gemini model (keys added via bot)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Video storage path (default: data/videos)
# VIDEO_STORAGE_PATH=data/videos

# Optional: YouTube cookies. Upload via bot (Manage credentials → Upload YouTube cookies).
# Or set path to file. Default: cookies.txt in project root
# YT_COOKIES_PATH=cookies.txt

# Optional: HTTP proxy for YouTube downloads (helps if VPS IP is blocked by YouTube)
# YT_PROXY=http://user:pass@proxy.example.com:8080
