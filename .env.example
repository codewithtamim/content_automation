# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_CHAT_ID=your_chat_id
ADMIN_TELEGRAM_USERNAME=your_username

# Database (use host "db" when running in Docker)
DATABASE_URL=postgresql://tiktok:tiktok_secret@db:5432/tiktok_automation

# Optional: Gemini model (keys added via bot)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Video storage path (default: /tmp/videos)
# VIDEO_STORAGE_PATH=/tmp/videos

# Optional: YouTube cookies. Upload via bot (Manage credentials → Upload YouTube cookies).
# Or set path to file. Default: cookies.txt in project root
# YT_COOKIES_PATH=cookies.txt
